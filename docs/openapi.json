{
  "components": {
    "schemas": {
      "CreateInitiativeJob": {
        "properties": {
          "input": {
            "maxLength": 50000,
            "minLength": 1,
            "type": "string"
          },
          "pipelineId": {
            "minLength": 1,
            "type": "string"
          },
          "title": {
            "maxLength": 200,
            "type": "string"
          }
        },
        "required": [
          "pipelineId",
          "input"
        ],
        "type": "object"
      },
      "CreatePublicTask": {
        "properties": {
          "description": {
            "maxLength": 2000,
            "type": "string"
          },
          "taskType": {
            "enum": [
              "feature",
              "bug",
              "document",
              "spike",
              "review",
              "ralph"
            ],
            "type": "string"
          },
          "title": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "title"
        ],
        "type": "object"
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "properties": {
              "code": {
                "type": "string"
              },
              "details": {},
              "issues": {
                "items": {
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "path": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "message"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "type": "object"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "InitiativeAccepted": {
        "properties": {
          "jobId": {
            "type": "string"
          },
          "links": {
            "properties": {
              "events": {
                "type": "string"
              },
              "self": {
                "type": "string"
              }
            },
            "required": [
              "self",
              "events"
            ],
            "type": "object"
          },
          "status": {
            "enum": [
              "running",
              "succeeded",
              "failed"
            ],
            "type": "string"
          }
        },
        "required": [
          "jobId",
          "status",
          "links"
        ],
        "type": "object"
      },
      "PublicJob": {
        "properties": {
          "createdAt": {
            "type": "number"
          },
          "error": {
            "anyOf": [
              {
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                },
                "required": [
                  "code",
                  "message"
                ],
                "type": "object"
              },
              {
                "type": "null"
              }
            ]
          },
          "jobId": {
            "type": "string"
          },
          "pipelineId": {
            "type": "string"
          },
          "result": {
            "anyOf": [
              {
                "properties": {
                  "data": {
                    "anyOf": [
                      {},
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "output": {
                    "type": "string"
                  }
                },
                "required": [
                  "output",
                  "data"
                ],
                "type": "object"
              },
              {
                "type": "null"
              }
            ]
          },
          "status": {
            "enum": [
              "running",
              "succeeded",
              "failed"
            ],
            "type": "string"
          }
        },
        "required": [
          "jobId",
          "status",
          "pipelineId",
          "createdAt",
          "result",
          "error"
        ],
        "type": "object"
      },
      "PublicPipeline": {
        "properties": {
          "headlessStartable": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          },
          "pipelineId": {
            "type": "string"
          },
          "public": {
            "type": "boolean"
          },
          "steps": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "pipelineId",
          "name",
          "steps",
          "public",
          "headlessStartable"
        ],
        "type": "object"
      },
      "PublicPipelineList": {
        "properties": {
          "pipelines": {
            "items": {
              "$ref": "#/components/schemas/PublicPipeline"
            },
            "type": "array"
          }
        },
        "required": [
          "pipelines"
        ],
        "type": "object"
      },
      "PublicRun": {
        "properties": {
          "createdAt": {
            "type": "number"
          },
          "currentStep": {
            "type": "number"
          },
          "error": {
            "anyOf": [
              {
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                },
                "required": [
                  "code",
                  "message"
                ],
                "type": "object"
              },
              {
                "type": "null"
              }
            ]
          },
          "pullRequest": {
            "anyOf": [
              {
                "properties": {
                  "branch": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "url": {
                    "type": "string"
                  }
                },
                "required": [
                  "url",
                  "branch"
                ],
                "type": "object"
              },
              {
                "type": "null"
              }
            ]
          },
          "runId": {
            "type": "string"
          },
          "status": {
            "enum": [
              "running",
              "blocked",
              "paused",
              "done",
              "failed"
            ],
            "type": "string"
          },
          "steps": {
            "items": {
              "properties": {
                "agentKind": {
                  "type": "string"
                },
                "progress": {
                  "type": "number"
                },
                "state": {
                  "enum": [
                    "pending",
                    "working",
                    "waiting_decision",
                    "done"
                  ],
                  "type": "string"
                },
                "subtasks": {
                  "anyOf": [
                    {
                      "properties": {
                        "completed": {
                          "type": "number"
                        },
                        "inProgress": {
                          "type": "number"
                        },
                        "total": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "completed",
                        "inProgress",
                        "total"
                      ],
                      "type": "object"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              },
              "required": [
                "agentKind",
                "state",
                "progress",
                "subtasks"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "taskId": {
            "type": "string"
          }
        },
        "required": [
          "runId",
          "taskId",
          "status",
          "createdAt",
          "currentStep",
          "steps",
          "pullRequest",
          "error"
        ],
        "type": "object"
      },
      "PublicService": {
        "properties": {
          "description": {
            "type": "string"
          },
          "serviceId": {
            "type": "string"
          },
          "status": {
            "enum": [
              "planned",
              "ready",
              "in_progress",
              "blocked",
              "pr_ready",
              "done"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "enum": [
              "frontend",
              "service",
              "library",
              "document",
              "api",
              "database",
              "queue",
              "integration",
              "external",
              "environment"
            ],
            "type": "string"
          }
        },
        "required": [
          "serviceId",
          "title",
          "description",
          "type",
          "status"
        ],
        "type": "object"
      },
      "PublicServiceList": {
        "properties": {
          "services": {
            "items": {
              "$ref": "#/components/schemas/PublicService"
            },
            "type": "array"
          }
        },
        "required": [
          "services"
        ],
        "type": "object"
      },
      "PublicTask": {
        "properties": {
          "description": {
            "type": "string"
          },
          "executionId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "progress": {
            "type": "number"
          },
          "pullRequestUrl": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "serviceId": {
            "type": "string"
          },
          "status": {
            "enum": [
              "planned",
              "ready",
              "in_progress",
              "blocked",
              "pr_ready",
              "done"
            ],
            "type": "string"
          },
          "taskId": {
            "type": "string"
          },
          "taskType": {
            "enum": [
              "feature",
              "bug",
              "document",
              "spike",
              "review",
              "ralph",
              "recurring"
            ],
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "taskId",
          "serviceId",
          "title",
          "description",
          "taskType",
          "status",
          "progress",
          "executionId",
          "pullRequestUrl"
        ],
        "type": "object"
      },
      "PublicTaskList": {
        "properties": {
          "tasks": {
            "items": {
              "$ref": "#/components/schemas/PublicTask"
            },
            "type": "array"
          }
        },
        "required": [
          "tasks"
        ],
        "type": "object"
      },
      "StartPublicTask": {
        "properties": {
          "pipelineId": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [],
        "type": "object"
      },
      "UpdatePublicTask": {
        "properties": {
          "description": {
            "maxLength": 2000,
            "type": "string"
          },
          "title": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [],
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "description": "A public-API key of the form `cf_live_<keyId>.<secret>`.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "The external, key-authenticated API (`/api/v1`). Authenticate every request with a public-API key: `Authorization: Bearer cf_live_<keyId>.<secret>`. Every call is scoped to the key’s workspace.",
    "license": {
      "identifier": "MIT",
      "name": "MIT"
    },
    "title": "cat-factory Public API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/initiatives": {
      "post": {
        "description": "Start a public, inline pipeline headlessly against a supplied brief. Returns a job id to poll or stream. Nothing is pushed to GitHub.",
        "operationId": "createInitiativeJob",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInitiativeJob"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitiativeAccepted"
                }
              }
            },
            "description": "Accepted — the run has started"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "Start an initiative-breakdown run",
        "tags": [
          "Initiatives"
        ]
      }
    },
    "/api/v1/jobs/{id}": {
      "get": {
        "description": "Poll a headless initiative run started by this key: its status and, once finished, its result.",
        "operationId": "getPublicJob",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicJob"
                }
              }
            },
            "description": "Success"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "Get an initiative job",
        "tags": [
          "Initiatives"
        ]
      }
    },
    "/api/v1/jobs/{id}/events": {
      "get": {
        "description": "Server-sent events for a headless initiative run: `progress` frames until a terminal `done`/`error`/`stopped`/`timeout` event. Authenticated by the API key header.",
        "operationId": "streamPublicJobEvents",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "An event stream of job updates"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          }
        },
        "summary": "Stream an initiative job (SSE)",
        "tags": [
          "Initiatives"
        ]
      }
    },
    "/api/v1/pipelines": {
      "get": {
        "description": "List the pipelines in the key’s workspace — id/name/steps plus whether each is public and safe to run headlessly — so a caller can pick a pipelineId to start a task with.",
        "operationId": "listPublicPipelines",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicPipelineList"
                }
              }
            },
            "description": "Success"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "List the workspace's pipelines",
        "tags": [
          "Pipelines"
        ]
      }
    },
    "/api/v1/services": {
      "get": {
        "description": "List the board service frames in the key’s workspace, so a caller can discover the serviceId to create/list tasks under.",
        "operationId": "listPublicServices",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicServiceList"
                }
              }
            },
            "description": "Success"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "List the workspace's services",
        "tags": [
          "Services"
        ]
      }
    },
    "/api/v1/services/{serviceId}/tasks": {
      "get": {
        "description": "List every task under a service (the whole subtree — tasks directly under the frame and under its modules).",
        "operationId": "listPublicServiceTasks",
        "parameters": [
          {
            "in": "path",
            "name": "serviceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicTaskList"
                }
              }
            },
            "description": "Success"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "List a service's tasks",
        "tags": [
          "Tasks"
        ]
      },
      "post": {
        "description": "Create a task inside a service frame the key’s workspace owns. The task starts in the `planned` state; start it with the start endpoint.",
        "operationId": "createPublicTask",
        "parameters": [
          {
            "in": "path",
            "name": "serviceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePublicTask"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicTask"
                }
              }
            },
            "description": "Created"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "Create a task under a service",
        "tags": [
          "Tasks"
        ]
      }
    },
    "/api/v1/tasks/{taskId}": {
      "delete": {
        "operationId": "deletePublicTask",
        "parameters": [
          {
            "in": "path",
            "name": "taskId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No content"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "deletePublicTask",
        "tags": [
          "Public API"
        ]
      },
      "get": {
        "description": "Read a task’s current lifecycle status, run progress, execution id, and PR URL (once one exists).",
        "operationId": "getPublicTask",
        "parameters": [
          {
            "in": "path",
            "name": "taskId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicTask"
                }
              }
            },
            "description": "Success"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "Get a task's status",
        "tags": [
          "Tasks"
        ]
      },
      "patch": {
        "description": "Edit a task’s human-authored fields (title/description) before it runs. Both fields are optional.",
        "operationId": "updatePublicTask",
        "parameters": [
          {
            "in": "path",
            "name": "taskId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePublicTask"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicTask"
                }
              }
            },
            "description": "Success"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Client error (validation, unauthorized, not found, conflict, rate limit)"
          },
          "5XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Server error"
          }
        },
        "summary": "Edit a task's title/description",
        "tags": [
          "Tasks"
        ]
      }
    },
    "/api/v1/tasks/{taskId}/events": {
      "get": {
        "description": "Server-sent events for a board task run: `progress` frames (the rich run projection) until a terminal `done`/`error` event, or a `timeout` when the connection cap is reached. Authenticated by the API key header.",
        "operationId": "streamPublicTaskRun",
        "parameters": [
          {
            "in": "path",
            "name": "taskId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "description": "An event stream of run updates"
          },
          "4XX": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
