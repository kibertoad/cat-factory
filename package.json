{
  "name": "cat-factory",
  "private": true,
  "description": "Agent Architecture Board — monorepo of reusable libraries (published to npm) + example deployments. See README.md.",
  "type": "module",
  "scripts": {
    "build": "tsgo -b backend/tsconfig.build.json",
    "typecheck": "pnpm build && pnpm -r run typecheck",
    "test": "pnpm test:run",
    "test:run": "pnpm build && pnpm -r run test:run",
    "lint": "oxlint && oxfmt --check .",
    "lint:fix": "oxlint --fix && oxfmt .",
    "dev:backend": "pnpm --filter @cat-factory/deploy-backend run dev",
    "dev:node": "pnpm --filter @cat-factory/deploy-node run dev",
    "dev:frontend": "pnpm --filter @cat-factory/deploy-frontend run dev",
    "changeset": "changeset",
    "version": "changeset version",
    "ci:publish": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@typescript/native-preview": "7.0.0-dev.20260616.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.6.0"
}
