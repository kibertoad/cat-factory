{
  "name": "cat-factory",
  "private": true,
  "description": "Agent Architecture Board — monorepo of reusable libraries (published to npm) + example deployments. See README.md.",
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter='./backend/**'",
    "build:all": "turbo run build",
    "build:tsc": "tsc -b backend/tsconfig.build.json",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test:run",
    "test:run": "turbo run test:run",
    "lint": "oxlint && oxfmt --check .",
    "lint:fix": "oxlint --fix && oxfmt .",
    "lint:monorepo": "sherif -i typescript -i @types/node",
    "lint:knip": "knip",
    "check:publish": "node scripts/check-publish-integrity.mjs",
    "dev:backend": "turbo run dev --filter=@cat-factory/deploy-backend",
    "dev:node": "turbo run dev --filter=@cat-factory/deploy-node",
    "dev:frontend": "turbo run dev --filter=@cat-factory/deploy-frontend",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-runner-image-tags.mjs",
    "sync:image-tags": "node scripts/sync-runner-image-tags.mjs",
    "ci:publish": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.31.0",
    "knip": "^6.26.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.73.0",
    "publint": "^0.3.21",
    "sherif": "^1.13.0",
    "turbo": "^2.10.4",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0"
}
