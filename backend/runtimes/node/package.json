{
  "name": "@cat-factory/node-server",
  "version": "0.106.8",
  "description": "Node.js runtime facade for the Agent Architecture Board: serves the shared @cat-factory/server Hono app via @hono/node-server, wiring Node implementations of the runtime ports (persistence, gateways, model provisioning).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/runtimes/node"
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "build:watch": "tsc -b tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "dev": "node --watch dist/main.js",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:rebase-snapshot": "node scripts/rebase-migration-snapshot.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "test": "vitest run",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@cat-factory/agents": "workspace:*",
    "@cat-factory/caching": "workspace:*",
    "@cat-factory/consensus": "workspace:*",
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/eks": "workspace:*",
    "@cat-factory/gates": "workspace:*",
    "@cat-factory/gitlab": "workspace:*",
    "@cat-factory/integrations": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "@cat-factory/observability-langfuse": "workspace:*",
    "@cat-factory/observability-otel": "workspace:*",
    "@cat-factory/orchestration": "workspace:*",
    "@cat-factory/prompt-fragments": "workspace:*",
    "@cat-factory/provider-bedrock": "workspace:*",
    "@cat-factory/provider-cloudflare": "workspace:*",
    "@cat-factory/provider-s3": "workspace:*",
    "@cat-factory/server": "workspace:*",
    "@cat-factory/spend": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "drizzle-orm": "1.0.0-rc.4",
    "hono": "^4.12.30",
    "layered-loader": "^14.5.3",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.1",
    "toad-scheduler": "^4.1.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@cat-factory/conformance": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "1.0.0-rc.4",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "ioredis": "^5.11.1"
  }
}
