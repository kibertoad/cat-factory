{
  "name": "@cat-factory/worker",
  "version": "0.51.5",
  "description": "Reusable Cloudflare Worker library (Hono + D1) exposing the Agent Architecture Board core: the `createApp()` Hono factory, the default fetch/scheduled/queue handler, and the Durable Object + Workflow classes. Deployments (see deploy/backend) supply the wrangler.toml + config and re-export these.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/runtimes/cloudflare"
  },
  "files": [
    "dist",
    "migrations",
    "telemetry-migrations",
    "sandbox-migrations",
    "migrations-provisioning"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "dev": "wrangler dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply cat_factory --local",
    "db:migrate:provisioning:local": "wrangler d1 migrations apply cat_factory_provisioning --local"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.89",
    "@ai-sdk/openai": "^3.0.77",
    "@ai-sdk/openai-compatible": "^2.0.54",
    "@cat-factory/agents": "workspace:*",
    "@cat-factory/consensus": "workspace:*",
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/gates": "workspace:*",
    "@cat-factory/gitlab": "workspace:*",
    "@cat-factory/integrations": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "@cat-factory/observability-langfuse": "workspace:*",
    "@cat-factory/orchestration": "workspace:*",
    "@cat-factory/prompt-fragments": "workspace:*",
    "@cat-factory/provider-cloudflare": "workspace:*",
    "@cat-factory/server": "workspace:*",
    "@cat-factory/spend": "workspace:*",
    "@cloudflare/containers": "^0.3.7",
    "@hono/valibot-validator": "^0.6.1",
    "ai": "^6.0.214",
    "hono": "^4.12.27",
    "pino": "^10.3.1",
    "valibot": "^1.4.2",
    "workers-ai-provider": "^3.2.1"
  },
  "devDependencies": {
    "@cat-factory/conformance": "workspace:*",
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@cloudflare/workers-types": "^4.20260628.1",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
