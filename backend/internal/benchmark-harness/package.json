{
  "name": "@cat-factory/benchmark-harness",
  "version": "0.6.0",
  "private": true,
  "description": "Headless harness for benchmarking cat-factory agents (requirement review, implementation, code review) across models and prompt versions, graded by a Claude Arbiter skill.",
  "bin": {
    "cat-bench": "./src/cli.ts"
  },
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "bench": "node --experimental-strip-types src/cli.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.92",
    "@ai-sdk/openai": "^3.0.80",
    "@ai-sdk/openai-compatible": "^2.0.56",
    "@cat-factory/agents": "workspace:*",
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/executor-harness": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "@cat-factory/orchestration": "workspace:*",
    "@cat-factory/spend": "workspace:*",
    "ai": "^6.0.219",
    "valibot": "^1.4.2",
    "workers-ai-provider": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  }
}
