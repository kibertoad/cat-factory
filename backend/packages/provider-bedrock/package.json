{
  "name": "@cat-factory/provider-bedrock",
  "version": "0.7.217",
  "description": "Opt-in AWS Bedrock model registry for the Agent Architecture Board's AI provisioning facade. Mix into a CompositeModelProvider to add the `bedrock` provider.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/packages/provider-bedrock"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.133",
    "@cat-factory/agents": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "ai": "^6.0.224"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
