{
  "name": "@cat-factory/workspaces",
  "version": "0.7.35",
  "description": "Tenancy base services (workspaces and accounts) for the Agent Architecture Board.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/packages/workspaces"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/kernel": "workspace:*"
  },
  "devDependencies": {
    "typescript": "7.0.1-rc"
  }
}
