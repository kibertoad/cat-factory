{
  "name": "@cat-factory/integrations",
  "version": "0.81.16",
  "description": "External-system integration domain logic for the Agent Architecture Board (GitHub, documents, tasks, environments, runners).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/packages/integrations"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "pilot:golden": "node scripts/pilot-detect-golden.mjs"
  },
  "dependencies": {
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "ai": "^6.0.224",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@cat-factory/caching": "workspace:*",
    "typescript": "7.0.2",
    "undici": "^8.7.0",
    "valibot": "^1.4.2",
    "vitest": "^4.1.10"
  }
}
