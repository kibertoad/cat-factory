# Sanitized fixture — the committed env template the shared stack materializes into its
# gitignored target `.env.shared` before `up`. The detector pairs `.env.shared.example`
# -> `.env.shared` as a `RecipeEnvFile`. Values are placeholders (no real secrets).
COMPOSE_PROJECT_NAME=acme-shared-services
MYSQL_ROOT_PASSWORD=changeme
POSTGRES_PASSWORD=changeme
