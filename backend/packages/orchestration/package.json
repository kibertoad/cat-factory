{
  "name": "@cat-factory/orchestration",
  "version": "1.0.0",
  "description": "Delivery-workflow engine for the Agent Architecture Board (execution, bootstrap, pipelines, board, boardScan, requirements, and composition root).",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@cat-factory/agents": "workspace:*",
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/integrations": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "@cat-factory/spend": "workspace:*",
    "@cat-factory/workspaces": "workspace:*",
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.8"
  }
}
