{
  "name": "@cat-factory/core",
  "version": "1.0.0",
  "description": "Framework-agnostic domain logic for the Agent Architecture Board.",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "precompile:templates": "node scripts/precompile-prompts.mjs"
  },
  "dependencies": {
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/prompt-fragments": "workspace:*",
    "ai": "^6.0.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
