{
  "name": "@cat-factory/sandbox",
  "version": "0.8.88",
  "description": "Parallel prompt/model testing surface: versioned prompt candidates, experiment matrices, judge + objective grading. Isolated from the core product so it can be extracted.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/packages/sandbox"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@cat-factory/agents": "workspace:*",
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "@cat-factory/sandbox-fixtures": "workspace:*"
  },
  "devDependencies": {
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  }
}
