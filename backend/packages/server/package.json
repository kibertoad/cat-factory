{
  "name": "@cat-factory/server",
  "version": "0.18.0",
  "description": "Runtime-neutral HTTP layer for the Agent Architecture Board: the Hono controllers, middleware (auth/authz/CORS/error), request helpers and the gateway seams shared by every deployment facade (Cloudflare Worker, Node service).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/packages/server"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@cat-factory/agents": "workspace:*",
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/integrations": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "@cat-factory/orchestration": "workspace:*",
    "@cat-factory/prompt-fragments": "workspace:*",
    "@cat-factory/spend": "workspace:*",
    "@hono/valibot-validator": "^0.6.1",
    "hono": "^4.12.27",
    "pino": "^10.3.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  }
}
