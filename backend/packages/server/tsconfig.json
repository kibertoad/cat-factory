{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    // Runtime-neutral but Web-standard: it runs on both workerd and Node, so it
    // relies on the Web Platform globals (Response, Request, crypto, fetch,
    // atob/btoa, TextEncoder, console) rather than any Cloudflare or Node types.
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  // Typecheck config: covers tests too. `rootDir` lives in tsconfig.build.json so
  // the emitted build stays src-only while typecheck spans src + test.
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
