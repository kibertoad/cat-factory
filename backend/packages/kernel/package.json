{
  "name": "@cat-factory/kernel",
  "version": "0.61.1",
  "description": "Shared vocabulary, pure logic, and port interfaces for the Agent Architecture Board.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/packages/kernel"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cat-factory/contracts": "workspace:*",
    "ai": "^6.0.214"
  },
  "devDependencies": {
    "typescript": "7.0.1-rc"
  }
}
