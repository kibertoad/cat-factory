{
  "name": "@cat-factory/agents",
  "version": "0.26.0",
  "description": "Agent catalog, routing, prompts and fragment library for the Agent Architecture Board.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/packages/agents"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "precompile:templates": "node scripts/precompile-prompts.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.89",
    "@ai-sdk/openai": "^3.0.77",
    "@ai-sdk/openai-compatible": "^2.0.54",
    "@ai-sdk/provider": "^3.0.12",
    "@cat-factory/contracts": "workspace:*",
    "@cat-factory/kernel": "workspace:*",
    "@cat-factory/prompt-fragments": "workspace:*",
    "ai": "^6.0.214",
    "handlebars": "^4.7.9",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  }
}
