{
  "name": "@cat-factory/prompt-fragments",
  "version": "0.13.37",
  "description": "Curated, versioned best-practice prompt fragments injected into agent system prompts.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kibertoad/cat-factory.git",
    "directory": "backend/packages/prompt-fragments"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@cat-factory/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
