# Environment for the Node.js service deployment. Copy to `.env` (gitignored); the
# `dev`/`start` scripts load it with Node's NATIVE `--env-file-if-exists` flag (no
# dotenv). In production, inject these through your orchestrator instead of a file.

# --- Required ---------------------------------------------------------------
# Postgres connection string. The server runs the schema migration on boot.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/cat_factory

# --- Server -----------------------------------------------------------------
# Listen port (default 8787).
PORT=8787
# Comma-separated allowed CORS origins (the SPA's origin). Empty = none allowed.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Real-time cross-node propagation (optional; multi-node only) ------------
# A single Node replica needs nothing here: its in-process hub reaches every
# browser it serves. Run MORE THAN ONE replica and a browser on node A must also
# see events produced on node B — set REDIS_URL to fan real-time events across
# nodes over Redis pub/sub (requires the optional `ioredis` dependency, installed
# by default). Leave unset for single-node / local mode.
# REDIS_URL=redis://localhost:6379
# Pub/sub channel (default cat-factory:realtime).
# REDIS_REALTIME_CHANNEL=cat-factory:realtime
# Optional readable prefix for this node's echo-suppression id (default a random uuid). A
# per-process random suffix is always appended, so it is safe to set the same value on every
# replica — the effective id stays unique per process.
# REALTIME_NODE_ID=

# --- Auth -------------------------------------------------------------------
# The auth gate FAILS CLOSED: with the OAuth/session secrets unset it refuses
# protected routes (503). AUTH_DEV_OPEN is the LOCAL-ONLY escape hatch to run open
# while developing; it is ignored when ENVIRONMENT is production/prod/staging and
# must NEVER be set in a real deployment.
AUTH_DEV_OPEN=true
ENVIRONMENT=development
# Production auth (all three required to enable real sessions):
# AUTH_SESSION_SECRET=            # >= 32 chars
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# Optional auth tuning:
# AUTH_SESSION_TTL_HOURS=168
# AUTH_SUCCESS_REDIRECT_URL=
# AUTH_CALLBACK_URL=
# AUTH_ALLOWED_LOGINS=            # comma-separated GitHub logins
# AUTH_ALLOWED_ORGS=             # comma-separated GitHub orgs
# AUTH_ALLOWED_REDIRECT_ORIGINS=
# Email/password login (needs a strong AUTH_SESSION_SECRET):
# AUTH_PASSWORD_ENABLED=true
# Google OAuth login (both required to enable):
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URL=      # else derived from the request origin
# New-user self-signup allowlist (else signup is invite-only):
# AUTH_ALLOWED_EMAIL_DOMAINS=     # comma-separated email domains

# --- Email (invitations) ----------------------------------------------------
# Transactional email is available whenever ENCRYPTION_KEY is set (no opt-in flag).
# The provider + API key + From address are onboarded PER-ACCOUNT in the UI and stored
# sealed in the DB (under ENCRYPTION_KEY) — not here.
# APP_BASE_URL=                   # SPA origin the invite/reset link points at
# Deployment-level "system" sender for auth emails (password reset), independent of the
# per-account connections. All three must be set for reset links to be emailed; absent,
# the reset link is logged instead. provider = sendgrid | resend.
# EMAIL_SYSTEM_PROVIDER=resend
# EMAIL_SYSTEM_FROM=no-reply@example.com
# EMAIL_SYSTEM_API_KEY=

# --- Models -----------------------------------------------------------------
# Unconfigured providers simply aren't registered, so a model pinned to one throws
# a clear "Unsupported model provider" instead of failing deep in the SDK.
#
# Direct vendor keys (OpenAI-compatible vendors upgrade from the fallback automatically):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# QWEN_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=
#
# OpenRouter + LiteLLM (OpenAI-compatible gateways). Their API keys are added per
# workspace/user via the UI (Settings → Direct provider API keys), NOT here. Only the
# base URLs are deployment config: OpenRouter defaults to the public gateway (override
# optional); LiteLLM is operator-hosted so its base URL is REQUIRED to enable it.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LITELLM_BASE_URL=http://localhost:4000/v1
#
# Cloudflare models over REST (no Workers binding on Node). Set both to enable;
# CLOUDFLARE_AI_GATEWAY is an optional AI Gateway base URL.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_AI_GATEWAY=
#
# AWS Bedrock (opt-in; registered only when BEDROCK_REGION is set). BEDROCK_MODELS is
# the comma-separated allow-list — models outside it throw "Unsupported Bedrock model".
# BEDROCK_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# BEDROCK_MODELS=anthropic.claude-3-5-sonnet-20241022-v2:0
#
# Default agent model routing (optional; sensible defaults otherwise):
# AGENT_DEFAULT_PROVIDER=
# AGENT_DEFAULT_MODEL=
# AGENT_DEFAULT_TEMPERATURE=0.4
# AGENT_MAX_OUTPUT_TOKENS=5000

# --- Web search (optional; opt-in) ------------------------------------------
# Two independent surfaces, both off by default and keyless-in-the-sandbox:
#
# 1) CONTAINER agents (coder/ci-fixer/mocker/…) get web_search/web_fetch via a backend
#    search proxy — the key stays on the backend, never in the container. The per-account
#    upstream keys (Brave key, or a self-hosted SearXNG url [+ key]) are configured PER
#    ACCOUNT in the UI (account Deployment settings, admin only) and sealed in the DB
#    (requires ENCRYPTION_KEY). As a fallback for accounts with none set, you may configure
#    a DEPLOYMENT-WIDE default upstream here (trusted — a self-hosted SearXNG you run):
# WEB_SEARCH_SEARXNG_URL=          # e.g. http://searxng:8080 (a self-hosted instance you run)
# WEB_SEARCH_SEARXNG_API_KEY=      # only if it sits behind an auth proxy
# WEB_SEARCH_BRAVE_API_KEY=        # or hosted Brave Search as the default instead
#
# 2) INLINE design/research agents (architect/researcher) get the provider-hosted
#    web_search tool — only on Anthropic/OpenAI models (no effect on others).
# INLINE_WEB_SEARCH_ENABLED=true
# INLINE_WEB_SEARCH_KINDS=architect,researcher   # override the default allow-list
# INLINE_WEB_SEARCH_MAX_USES=5                    # cap per inline run (Anthropic maxUses)

# --- Spend safeguard --------------------------------------------------------
# The budget (currency, monthly limit, per-model price overrides) is configured PER
# WORKSPACE in the UI (Workspace settings → Budget) and persisted in the DB, not via env.
# A workspace with no budget set inherits the built-in default (~100 EUR/month).

# --- Execution tuning (optional) -------------------------------------------
# DECISION_TIMEOUT=24 hours
# JOB_POLL_INTERVAL=15 seconds
# JOB_MAX_POLLS=280
# JOB_POLL_FAILURE_TOLERANCE=6
# CI_POLL_INTERVAL=30 seconds
# CI_MAX_POLLS=120
# CONTAINER_MAX_AGE_MINUTES=90
#
# Durable execution worker (pg-boss). EXECUTION_CONCURRENCY is how many runs this node
# drives in parallel (independent workers; scale alongside the Postgres connection
# limit). The rest size pg-boss's job liveness — defaults are derived from the poll
# budgets above and rarely need tuning:
# EXECUTION_CONCURRENCY=10
# EXECUTION_HEARTBEAT_SECONDS=60        # crash detection; a dead worker's run re-drives within this
# EXECUTION_MAX_DRIVE_STEPS=16          # steps one drive may chain; sizes the job-expiry cap
# EXECUTION_DRIVE_EXPIRE_MINUTES=       # override the computed job-expiry cap outright
# STALE_RUN_SWEEP_MINUTES=5             # how often the backstop sweeper runs
# STALE_RUN_LEASE_MINUTES=10            # how stale a `running` run must be to re-drive

# --- Retention (optional) ---------------------------------------------------
# TOKEN_USAGE_RETENTION_DAYS=395
# GITHUB_RATE_LIMIT_RETENTION_DAYS=7
# GITHUB_COMMIT_RETENTION_DAYS=90

# --- LLM observability (optional) -------------------------------------------
# The proxy records one metric per container-agent model call. By default each
# metric keeps the complete prompt sent to the model; set this to false to drop the
# prompt body (the numeric telemetry — tokens, timing, finish reason, counts — is
# still recorded) for deployments that must not retain prompt text.
# LLM_RECORD_PROMPTS=false

# --- Langfuse trace sink (optional, opt-in) ---------------------------------
# Stream every LLM call — container-agent calls (via the proxy) AND inline calls
# (requirements review, document planner, fragment selector) — to Langfuse as a
# generation grouped under its run's trace. Off unless LANGFUSE_ENABLED=true and both
# keys are set. Honours LLM_RECORD_PROMPTS (prompts are omitted in Langfuse too when
# off). LANGFUSE_BASE_URL is optional and defaults to Langfuse Cloud.
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Credential encryption (REQUIRED) ---------------------------------------
# ONE shared master key encrypts every integration's per-workspace credentials at
# rest (the cipher domain-separates per integration internally, so one key is safe).
# The always-on Jira task-source integration FAILS TO BOOT (loud config error) until
# this is set.
ENCRYPTION_KEY=          # REQUIRED. base64, >= 32 bytes decoded (e.g. `openssl rand -base64 32`)

# --- Slack notifications (OPT-IN) -------------------------------------------
# Post board notifications (merge reviews, pipeline completions, CI failures) to
# Slack — an extra delivery transport for the same notification mechanism. Per-account
# connection (the bot token is encrypted at rest with ENCRYPTION_KEY above), per-board
# routing. Each org connects its OWN Slack via the UI: a full OAuth "Add to Slack" flow
# when the app credentials are set, else manual bot-token paste. The Slack app OAuth
# credentials (client id/secret/redirect) are now configured PER ACCOUNT in the UI
# (account Deployment settings, admin only) and sealed in the DB — no longer via env.
# SLACK_ENABLED=true         # opt-in; requires ENCRYPTION_KEY

# --- Datadog post-release-health (opt-in) -----------------------------------
# Enables the `post-release-health` pipeline gate: after a release ships it watches the
# workspace's configured observability monitors/SLOs (Datadog today) and, on a regression,
# spawns an on-call agent to investigate (a human decides whether to revert). The
# per-workspace provider credentials are connected in the UI and sealed at rest with
# ENCRYPTION_KEY (above).
# OBSERVABILITY_ENABLED=true       # opt-in; requires ENCRYPTION_KEY
# Optional incident enrichment: post the on-call investigation onto an incident PagerDuty
# / incident.io ALREADY opened from the same monitors/SLOs (annotate, never re-alert).
# The PagerDuty / incident.io credentials are now configured PER WORKSPACE in the UI
# (sealed in the DB), not via env.

# --- Task sources / Jira (ALWAYS ON) ----------------------------------------
# Lets each workspace (tenant) connect its OWN Jira site through the UI; the
# credentials are stored per-workspace, ENCRYPTED at rest with the key above — this
# is deployment config, NOT a tenant's tokens (those are entered in the app). Once a
# workspace connects Jira and selects it as its tracker, the tech-debt recurring
# pipeline files that workspace's ticket against that workspace's Jira.
#
# There is no source allow-list env: Jira is always available to connect, and GitHub
# Issues are offered automatically once a workspace installs the GitHub App. Each
# workspace toggles either source on/off in the UI (persisted in task_source_settings).
#
# Linear connects with a personal API key by default. To additionally offer the OAuth
# "Connect with Linear" button, register a Linear OAuth app and enter its client id /
# secret / redirect URL in the UI under the account's Deployment settings (sealed in the
# DB, like the Slack app OAuth credentials) — NOT via env.
#
# --- Consensus orchestration (optional) -------------------------------------
# Enable the multi-model consensus mechanism: registers the consensus capability
# traits (so the pipeline builder offers "Enable Consensus" on eligible steps) and
# wraps the agent executor to run consensus-enabled steps through a panel/debate/
# ranked-voting process. Off (unset) ⇒ unchanged single-actor behaviour. The core
# `task-estimator` step works regardless of this flag.
# CONSENSUS_ENABLED=true
