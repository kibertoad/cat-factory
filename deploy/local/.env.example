# --- Local-mode configuration (copy to .env) --------------------------------------
# Run the whole product on your machine: orchestrator as a Node process, each agent
# job as a local container (Docker/Podman/OrbStack/Colima/Apple `container`), GitHub
# via a PAT, persistence on a local Postgres.

# Postgres (the docker-compose service). Required.
DATABASE_URL=postgres://cat:cat@localhost:5432/catfactory

# The executor-harness image run per agent job. Required. Either pull the published
# GHCR image or build it locally from backend/internal/executor-harness/Dockerfile:
#   docker build -t cat-factory-executor:local backend/internal/executor-harness
LOCAL_HARNESS_IMAGE=cat-factory-executor:local

# GitHub personal access token used by the agent containers to clone, push branches
# and open PRs. A fine-grained token scoped to the target repo(s) with contents +
# pull-requests write is recommended. Required for repo-operating agent steps. When set,
# it also enables one-click "Continue with GitHub" on the local login screen (the PAT's
# account becomes your signed-in identity). Without it you can still paste a PAT at login.
GITHUB_PAT=

# GitLab personal access token (optional). When set, the local login screen offers
# one-click "Continue with GitLab" (the token's GitLab account becomes your identity).
# A token with the `api` scope works; `read_user` is enough for sign-in alone. You can
# also paste a GitLab PAT at login without setting this. For a self-managed instance,
# set GITLAB_API_BASE (e.g. https://gitlab.example.com/api/v4).
# GITLAB_PAT=
# GITLAB_API_BASE=

# The port the service listens on. PUBLIC_URL defaults to http://<host-alias>:<PORT> so
# job containers can reach the LLM proxy, where <host-alias> depends on the selected
# container runtime (see "Container runtime" below) — host.docker.internal for docker.
PORT=8787

# --- Container runtime (optional) ------------------------------------------------
# Which runtime spins up the per-run agent containers. Defaults to docker. Docker,
# Podman, OrbStack and Colima all speak the Docker CLI; Apple `container` (macOS) has
# its own. Selecting a runtime sets sensible defaults for the binary, the host alias
# the harness uses to reach this service, and whether the Tester's local infra works.
# LOCAL_CONTAINER_RUNTIME=docker        # docker | podman | orbstack | colima | apple
#
# Override the CLI binary explicitly (wins over the runtime's default; e.g. a full path).
# LOCAL_DOCKER_BINARY=docker
# Attach the docker-family containers to a named network.
# LOCAL_DOCKER_NETWORK=
# The hostname the harness uses to reach this service's LLM proxy. Defaults per runtime
# (host.docker.internal for Docker/Podman/OrbStack, host.lima.internal for Colima, the
# vmnet gateway for Apple). If the proxy is unreachable from a job container — common on
# Colima / Apple — set this (or PUBLIC_URL) to your machine's LAN IP.
# LOCAL_HARNESS_HOST_ALIAS=
# Docker-family only: add --add-host=<alias>:host-gateway (needed on Linux Docker;
# harmless on Docker Desktop/OrbStack; OFF by default for Colima/Apple). Explicit wins.
# LOCAL_DOCKER_ADD_HOST_GATEWAY=true
# The Tester ("test environment = local") stands the service's docker-compose infra up
# INSIDE its job container (Docker-in-Docker), which needs a privileged container. Set
# to false if your runtime runs nested containers without it (e.g. rootless Podman).
# Apple `container` cannot do DinD at all: a local-infra Tester run is refused there —
# use the ephemeral test environment (with an environment provider) or a "No infra
# dependencies" service. See README "Container runtimes" + "Running the Tester locally".
# LOCAL_DOCKER_PRIVILEGED_TEST_JOBS=true

# --- Warm container pool + checkout reuse -----------------------------------------
# These moved OUT of env into the DB: configure them in the UI under Integrations >
# "Local mode" (warm-pool size / pre-warm / max / idle timeout, and the per-repo
# checkout-reuse workspace root + dep-cache keep list). Off by default (cold-start per
# run). See README "Warm container pool".

# --- Native execution (optional; use your installed Claude Code / Codex) ----------
# Allow-list of subscription harnesses to run as a HOST PROCESS driving your OWN installed
# claude/codex CLI (ambient login) instead of a Docker container — no leased credential.
# Off by default. NO sandbox: the agent runs with your full host access + personal
# subscription. Only a step whose model maps to a listed harness's NATIVE vendor (Anthropic
# claude / OpenAI codex) goes native; GLM/Kimi/DeepSeek (reuse claude-code) and proxy models
# still use the container path (so they still need LOCAL_HARNESS_IMAGE). See README.
# LOCAL_NATIVE_AGENTS=              # e.g. claude-code,codex (empty = off)
# LOCAL_HARNESS_ENTRY=             # required when native: path to the harness server entry

# Shared key backing credential encryption at rest (document/task/runner/slack
# integrations, personal subscriptions). Local mode generates a per-process key when
# unset, so it is optional just to boot. Set it (base64, >=32 bytes) to keep encrypted
# credentials decryptable across restarts: ENCRYPTION_KEY=$(openssl rand -base64 32)
# ENCRYPTION_KEY=

# Model providers. At least one must be configured or the model picker shows nothing
# selectable (every model comes back available:false) and pipelines can't start. Agent
# containers never hold a provider key themselves — they reach models through this
# service's LLM proxy (/v1) — so the key lives here on the service.
#
# Cloudflare Workers AI over REST. There is NO Workers binding on Node/local, so the
# "workers-ai" models are served over the REST API and need BOTH of these set (this is
# what "Cloudflare AI in local mode" requires; see README "Using Cloudflare AI"):
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_AI_GATEWAY=          # optional: route through an AI Gateway slug instead
#
# Or a direct vendor key:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
#
# Or a LOCALLY-RUN model (Ollama / LM Studio / llama.cpp / vLLM / a custom
# OpenAI-compatible server): no env var — configure it in the UI under
# Configuration > "My local runners" (per user, stored in the DB, with a "Test
# connection" probe that lists the models your runner serves). Local models need
# no API key. Requires ENCRYPTION_KEY (generated per process when unset). The LLM
# proxy runs in THIS host process, so it reaches e.g. Ollama at localhost:11434
# directly. See README "Using a local model".

# Langfuse trace sink (opt-in): stream every LLM call — agent containers (via the
# proxy) AND inline calls (requirements review, doc planner, fragment selector) — to
# Langfuse, grouped under each run's trace. Off unless enabled with both keys.
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Slack notifications (opt-in): post board notifications to Slack. Per-account
# connection (bot token encrypted at rest with ENCRYPTION_KEY), per-board routing.
# Connect via the UI — OAuth "Add to Slack" when the app creds are set, else paste a bot
# token. The Slack app OAuth credentials are now configured PER ACCOUNT in the UI (account
# Deployment settings, admin only) and sealed in the DB — no longer via env.
# SLACK_ENABLED=true

# --- Datadog post-release-health (opt-in) -----------------------------------
# Watches the configured observability monitors/SLOs (Datadog today) after a release ships;
# on a regression an on-call agent investigates (a human decides whether to revert). Keys are
# connected in the UI and sealed with ENCRYPTION_KEY. Optional PagerDuty/incident.io
# enrichment posts the investigation onto an incident those systems already opened (annotate,
# not re-alert); those credentials are now configured PER WORKSPACE in the UI, not via env.
# OBSERVABILITY_ENABLED=true

# Sign-in (local mode). Local mode now REQUIRES sign-in: anonymous use can't store
# per-user credentials (personal subscriptions, your own API keys), so the SPA shows a
# login screen. You sign in by (a) one-click with a configured GITHUB_PAT / GITLAB_PAT,
# (b) pasting a source-control PAT at login, or (c) email + password. A session secret is
# auto-generated if unset (set it to keep sessions valid across restarts). The API itself
# still runs dev-open for unauthenticated reads (AUTH_DEV_OPEN=true) — a real session
# unlocks the per-user features. The defaults below are applied automatically; override
# only to change them.
# AUTH_SESSION_SECRET=
# AUTH_PASSWORD_ENABLED=true      # email/password sign-in (on by default in local mode)
# AUTH_OPEN_SIGNUP=true           # create a local account with no invite (on by default)
# AUTH_DEV_OPEN=true              # keep the API open for unauthenticated reads
# AUTH_ALLOWED_EMAIL_DOMAINS=     # only relevant if you turn AUTH_OPEN_SIGNUP off
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# Email invitations (available whenever ENCRYPTION_KEY is set; provider key onboarded
# per-account in the UI, sealed under ENCRYPTION_KEY):
# APP_BASE_URL=                   # SPA origin the invite/reset link points at
# System sender for auth emails (password reset). Without it, the reset link is logged
# to the server console — handy for local testing. provider = sendgrid | resend.
# EMAIL_SYSTEM_PROVIDER=resend
# EMAIL_SYSTEM_FROM=no-reply@example.com
# EMAIL_SYSTEM_API_KEY=

# SECURITY: with the gate OPEN the server binds to all interfaces (so on native Linux
# Docker the job containers can reach the LLM proxy via the bridge gateway), meaning
# anyone on your network can reach the API. To lock it down either close the gate
# (AUTH_DEV_OPEN=false) or bind to loopback (HOST=127.0.0.1). Note: HOST=127.0.0.1
# works on Docker Desktop (host.docker.internal still resolves to the host) but NOT on
# native Linux Docker, where the agent containers reach the proxy via the bridge
# gateway IP — keep the default bind there and close the gate instead.
# HOST=127.0.0.1
#
# --- Consensus orchestration (optional) -------------------------------------------
# Enable the multi-model consensus mechanism (specialist panel / debate / ranked
# voting) on eligible steps + the "Enable Consensus" builder toggle. Off ⇒ unchanged.
# CONSENSUS_ENABLED=true
