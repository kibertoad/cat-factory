{
  "name": "@cat-factory/deploy-frontend",
  "version": "0.6.0",
  "private": true,
  "description": "Example Cloudflare Pages deployment of the Agent Architecture Board SPA. Extends the @cat-factory/app Nuxt layer; copy this package to deploy the frontend on your own Cloudflare account.",
  "type": "module",
  "scripts": {
    "postinstall": "nuxt prepare",
    "predev": "pnpm --filter @cat-factory/contracts run build",
    "dev": "nuxt dev",
    "prebuild": "pnpm --filter @cat-factory/contracts run build",
    "build": "nuxt build",
    "pregenerate": "pnpm --filter @cat-factory/contracts run build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "deploy": "wrangler pages deploy"
  },
  "dependencies": {
    "@cat-factory/app": "workspace:*",
    "nuxt": "^4.4.8"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.104.0"
  }
}
