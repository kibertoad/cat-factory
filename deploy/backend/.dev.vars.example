# Local development variables for `wrangler dev` — copy to `.dev.vars` (gitignored).
#
# The auth gate fails closed in production: with OAuth/session secrets unset, the
# API refuses protected routes (503). This flag is the LOCAL-ONLY escape hatch
# that lets you run the worker open while developing. It must NEVER be set in the
# deployed wrangler.toml — production is always authenticated.
AUTH_DEV_OPEN=true

# In production these are set as Worker secrets (`wrangler secret put NAME`), not
# here. For local dev against real integrations you can put them in .dev.vars:
# GITHUB_OAUTH_CLIENT_SECRET=...
# AUTH_SESSION_SECRET=...
# GITHUB_APP_PRIVATE_KEY=...
# GITHUB_WEBHOOK_SECRET=...
# QWEN_API_KEY=...
# DOCUMENTS_ENCRYPTION_KEY=...
# TASKS_ENCRYPTION_KEY=...
# ENVIRONMENTS_ENCRYPTION_KEY=...
# RUNNERS_ENCRYPTION_KEY=...
